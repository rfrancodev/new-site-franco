# Configuração de Variáveis de Ambiente - site Franco Desenvolvedor

# VITE_API_URL: URL do servidor backend de API (Google Cloud Run / AI Studio Preview).
# Em ambiente de desenvolvimento local ou preview, define o destino das requisições do frontend.
# Em produção no Cloudflare Pages (se deixado em branco), o frontend usará automaticamente chamadas relativas (/api/leads) integradas ao banco de dados D1 local da Cloudflare.
# Exemplo: https://ais-pre-seu-id.us-west2.run.app
VITE_API_URL="https://insira_a_url_do_seu_backend.run.app"

# N8N_WEBHOOK_URL: URL do Webhook do seu fluxo de trabalho no n8n.
# Usada pelas APIs de processamento para enviar as informações do Lead de forma assíncrona.
# Exemplo: https://n8n.seudominio.com/webhook/uuid-do-fluxo
N8N_WEBHOOK_URL="https://n8n.seu-dominio.com/webhook/insira_aqui_o_id_do_seu_webhook"

# GOOGLE_SHEETS_SCRIPT_URL: URL do Web App do Google Apps Script para salvar leads diretamente em uma planilha (opcional).
GOOGLE_SHEETS_SCRIPT_URL="https://script.google.com/macros/s/insira_o_id_do_seu_script/exec"

# APP_URL: URL principal onde o applet ou site está hospedado.
# Exemplo: https://seu-site.com
APP_URL="https://seu-site-producao.com"
